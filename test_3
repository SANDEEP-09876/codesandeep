@app.route('/')
def index():
    try:
        with open("index.html", "r") as f:
            return f.read()
    except FileNotFoundError:
        return "<h1>Error: index.html not found in the same folder!</h1>"

@app.route('/api/base')
def api_base():
    d = request.args.get('dir', 'stop')
    drive_base(d, 0, 70) if d != 'stop' else drive_base('stop', 0, 0)
    return jsonify({"status": "moved", "dir": d})

@app.route('/api/arm')
def api_arm():
    ch, ang = int(request.args.get('ch', 0)), int(request.args.get('ang', 90))
    set_arm_servo(ch, ang)
    return jsonify({"status": "moved", "ch": ch, "ang": ang})

@app.route('/api/sensor')
def api_sensor():
    if sensor_connected:
        return jsonify({"distance_cm": round(sensor.distance * 100, 1)})
    return jsonify({"distance_cm": "Offline"})

@app.route('/api/ai_chat')
def api_ai_chat():
    user_input = request.args.get('text', '')
    prompt = f"""
    You are the brain of a Robot. Tools available:
    - Wheels: actions "drive", dirs "forward", "backward", "left", "right"
    - Arm: actions "arm", channels 0 (Base), 1 (Shoulder), 2 (Elbow), 3 (Wrist), 4 (Gripper). Max angle 180.
    USER REQUEST: "{user_input}"
    Respond ONLY with a JSON list of steps. 
    Example: [{{"action": "arm", "channel": 0, "angle": 90}}, {{"action": "drive", "dir": "forward", "seconds": 2}}]
    """
    
    try:
        response = client.models.generate_content(
            model='gemini-2.5-flash',
            contents=prompt,
        )
        
        clean_json = response.text.replace('```json', '').replace('```', '').strip()
        
        def run_ai_logic():
            commands = json.loads(clean_json)
            for cmd in commands:
                if cmd.get("action") == "drive":
                    m_val = float(cmd.get("seconds", 1)) / SEC_PER_METER 
                    drive_base(cmd.get("dir"), m_val, 70)
                elif cmd.get("action") == "arm":
                    set_arm_servo(cmd.get("channel"), cmd.get("angle"))
                    time.sleep(0.5)

        threading.Thread(target=run_ai_logic).start()
        return jsonify({"ai_thought": clean_json})
    except Exception as e:
        return jsonify({"error": str(e)})

